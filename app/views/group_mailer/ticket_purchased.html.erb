<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html dir="ltr" lang="en">

  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
    <title>New Ticket Purchase - <%= @group.display_name %></title>
  </head>

  <body style="padding-left:1rem;padding-right:1rem">
    <table align="center" width="100%" class="border-box" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="max-width:37.5em">
      <tbody>
        <tr style="width:100%">
          <td><a href="https://app.sola.day/group/<%= @group.handle || @group.id %>" style="color:rgb(39,41,40);text-decoration:none;display:block;vertical-align:middle;flex-wrap:nowrap;margin-top:3rem;margin-bottom:3rem;line-height:32px" target="_blank"><img alt="" height="32" src="https://ik.imagekit.io/soladata/g9orl7uo_Xf0S5pGU4" style="display:inline-block;outline:none;border:none;text-decoration:none;border-radius:9999px;margin-right:0.5rem;vertical-align:middle" width="32" /><%= @group.display_name %></a>
            <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation">
              <tbody style="width:100%">
                <tr style="width:100%">
                  <td data-id="__react-email-column">
                    <div style="line-height:1.375;color:rgb(82,82,82);font-size:32px;font-weight:400;margin-bottom:3rem">New Ticket Purchase</div>
                  </td>
                </tr>
              </tbody>
            </table>
            <p style="font-size:16px;line-height:24px;margin-bottom:2rem;color:rgb(0,0,0)">
              A new ticket has been purchased for your group.
            </p>
            <% if @ticket_item.profile.present? %>
            <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin-bottom:2rem">
              <tbody style="width:100%">
                <tr style="width:100%">
                  <td data-id="__react-email-column">
                    <p style="font-size:14px;line-height:24px;margin:16px 0;color:rgb(0,0,0)">
                      <strong>Purchaser:</strong> <%= @ticket_item.profile.handle || @ticket_item.profile.email %>
                    </p>
                  </td>
                </tr>
              </tbody>
            </table>
            <% end %>
            <% if @ticket_item.event.present? %>
            <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin-bottom:2rem">
              <tbody style="width:100%">
                <tr style="width:100%">
                  <td data-id="__react-email-column">
                    <p style="font-size:14px;line-height:24px;margin:16px 0;color:rgb(0,0,0)">
                      <strong>Event:</strong> <%= @ticket_item.event.title %>
                    </p>
                  </td>
                </tr>
              </tbody>
            </table>
            <% end %>
            <% if @ticket_item.ticket.present? %>
            <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin-bottom:2rem">
              <tbody style="width:100%">
                <tr style="width:100%">
                  <td data-id="__react-email-column">
                    <p style="font-size:14px;line-height:24px;margin:16px 0;color:rgb(0,0,0)">
                      <strong>Ticket:</strong> <%= @ticket_item.ticket.content %>
                    </p>
                  </td>
                </tr>
              </tbody>
            </table>
            <% end %>
            <% if @ticket_item.amount.present? && @ticket_item.amount > 0 %>
            <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin-bottom:2rem">
              <tbody style="width:100%">
                <tr style="width:100%">
                  <td data-id="__react-email-column">
                    <p style="font-size:14px;line-height:24px;margin:16px 0;color:rgb(0,0,0)">
                      <strong>Amount:</strong> $<%= sprintf("%.2f", @ticket_item.amount / 100.0) %>
                    </p>
                  </td>
                </tr>
              </tbody>
            </table>
            <% end %>
            <% if @ticket_item.order_number.present? %>
            <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin-bottom:3rem">
              <tbody style="width:100%">
                <tr style="width:100%">
                  <td data-id="__react-email-column">
                    <p style="font-size:14px;line-height:24px;margin:16px 0;color:rgb(0,0,0)">
                      <strong>Order Number:</strong> <%= @ticket_item.order_number %>
                    </p>
                  </td>
                </tr>
              </tbody>
            </table>
            <% end %>
            <a href="https://app.sola.day/group/<%= @group.handle || @group.id %>" style="color:rgb(255,255,255);text-decoration:none;display:inline-flex;padding-left:3rem;padding-right:3rem;width:auto;justify-content:center;align-items:center;height:56px;position:relative;background-color:rgb(39,39,42);border-radius:1rem;text-align:center;font-weight:700" target="_blank">
              <div style="text-align:center;color:rgb(255,255,255);font-size:1rem;line-height:56px;vertical-align:middle;font-weight:700">View Group</div>
            </a>
            <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin-top:3rem">
              <tbody style="width:100%">
                <tr style="width:100%">
                  <td data-id="__react-email-column">
                    <div>
                      <div class="text-l md-1" style="line-height:normal">For more events go to<a href="https://app.sola.day" style="color:rgb(116,146,239);text-decoration:none;margin-left:0.5rem;margin-right:0.5rem" target="_blank">Social Layer↗</a></div><img alt="" src="https://ik.imagekit.io/soladata/fr550sre_BVy4kGMS7" style="width:102px;height:32px" />
                    </div>
                  </td>
                  <td data-id="__react-email-column">
                    <div><a href="https://twitter.com/SocialLayer_im" style="color:#067df7;text-decoration:none;display:inline-flex;flex-direction:row;align-items:center" target="_blank"><img alt="" src="https://ik.imagekit.io/soladata/eb4no7hp_n30ZYj04x" style="width:16px;height:16px" /><span style="color:rgb(0,0,0);margin-left:0.25rem;margin-right:0.25rem">@Social_Layer</span></a></div>
                  </td>
                </tr>
              </tbody>
            </table>
          </td>
        </tr>
      </tbody>
    </table>
  </body>

</html>
