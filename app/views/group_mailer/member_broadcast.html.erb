<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html dir="ltr" lang="en">
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
  </head>
  <body style="padding-left:1rem;padding-right:1rem;font-family:sans-serif">
    <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="max-width:37.5em">
      <tbody>
        <tr style="width:100%">
          <td>
            <a href="https://app.sola.day/event/<%= @group.handle %>" style="color:rgb(39,41,40);text-decoration:none;display:block;vertical-align:middle;flex-wrap:nowrap;margin-top:3rem;margin-bottom:2rem;line-height:32px" target="_blank">
              <img alt="" height="32" src="https://ik.imagekit.io/soladata/g9orl7uo_Xf0S5pGU4" style="display:inline-block;outline:none;border:none;text-decoration:none;border-radius:9999px;margin-right:0.5rem;vertical-align:middle" width="32" />
              <%= @group.handle %>
            </a>

            <div style="line-height:1.6;color:rgb(39,39,42);font-size:15px;margin-bottom:3rem">
              <%= raw @content %>
            </div>

            <a href="https://app.sola.day/event/<%= @group.handle %>" style="color:rgb(255,255,255);text-decoration:none;display:inline-flex;padding-left:3rem;padding-right:3rem;width:auto;justify-content:center;align-items:center;height:56px;position:relative;background-color:rgb(39,39,42);border-radius:1rem;text-align:center;font-weight:700" target="_blank">
              <div style="text-align:center;color:rgb(255,255,255);font-size:1rem;line-height:56px;vertical-align:middle;font-weight:700">Visit <%= @group.handle %></div>
            </a>

            <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin-top:3rem">
              <tbody style="width:100%">
                <tr style="width:100%">
                  <td>
                    <div>
                      <div style="line-height:normal">For more events go to<a href="https://app.sola.day" style="color:rgb(116,146,239);text-decoration:none;margin-left:0.5rem;margin-right:0.5rem" target="_blank">Social Layer↗</a></div>
                      <img alt="" src="https://ik.imagekit.io/soladata/fr550sre_BVy4kGMS7" style="width:102px;height:32px" />
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </td>
        </tr>
      </tbody>
    </table>
  </body>
</html>
